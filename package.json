{
  "name": "kmsh-portfolio",
  "version": "2.3.0",
  "description": "Professional portfolio for Keshav Mishra (kmsh) - LLM and ML Engineer",
  "author": "Keshav Mishra <me@kmsh.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/keshav1998/magic-portfolio.git"
  },
  "homepage": "https://kmsh.dev",
  "bugs": {
    "url": "https://github.com/keshav1998/magic-portfolio/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "export": "next export",
    "lint": "biome ci --error-on-warnings --max-diagnostics=none .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --noEmit",
    "check": "biome check --write .",
    "check:all": "npm run type-check && npm run check",
    "cf:build": "NODE_OPTIONS=--no-deprecation opennextjs-cloudflare build",
    "cf:preview": "NODE_OPTIONS=--no-deprecation opennextjs-cloudflare build && NODE_OPTIONS=--no-deprecation opennextjs-cloudflare preview",
    "cf:deploy": "NODE_OPTIONS=--no-deprecation opennextjs-cloudflare build && NODE_OPTIONS=--no-deprecation opennextjs-cloudflare deploy",
    "cf:upload": "NODE_OPTIONS=--no-deprecation opennextjs-cloudflare build && NODE_OPTIONS=--no-deprecation opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "clean": "rm -rf .next out .turbo node_modules/.cache",
    "clean:all": "npm run clean && rm -rf node_modules",
    "prepare": "lefthook install || true",
    "ci": "npm run type-check && npm run lint && npm run build"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "16.2.4",
    "@once-ui-system/core": "^1.5.14",
    "@opennextjs/cloudflare": "1.19.5",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "gray-matter": "^4.0.3",
    "next": "16.2.4",
    "next-mdx-remote": "6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sass": "^1.97.3",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@evilmartians/lefthook": "^2.1.6",
    "@types/cookie": "^0.6.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "lint-staged": "^16.2.7",
    "typescript": "^6.0.3",
    "tzdata": "^1.0.47",
    "wrangler": "4.87.0"
  },
  "overrides": {
    "postcss": "8.5.13"
  }
}
