{
  "name": "kmsh-portfolio",
  "version": "2.3.0",
  "description": "Professional portfolio for Keshav Mishra (kmsh) - LLM and ML Engineer",
  "author": "Keshav Mishra <me@kmsh.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/keshav1998/magic-portfolio.git"
  },
  "homepage": "https://kmsh.dev",
  "bugs": {
    "url": "https://github.com/keshav1998/magic-portfolio/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "biome": "biome check .",
    "biome:fix": "biome check --write .",
    "biome:ci": "biome ci .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "prepare": "prek install || true",
    "pre-commit": "prek run --all-files",
    "validate": "pnpm typecheck && pnpm biome:ci"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "@once-ui-system/core": "^1.5.14",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "next-mdx-remote": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "sass": "^1.97.3",
    "transliteration": "^2.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@j178/prek": "^0.3.0",
    "@types/node": "^22.10.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "tzdata": "^1.0.47"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write"
    ],
    "*.md": [
      "npx markdownlint-cli2 --fix"
    ]
  }
}
